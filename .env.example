# Resend — envoi des emails formulaires
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=ISSA Capital <contact@issa-capital.com>
RESEND_TO_EMAIL=contact@issa-capital.com

# Umami — analytics open source cookieless
# Le website ID est embarqué directement dans layout.tsx — pas d'env var nécessaire

# Site URL — canonical, OG, sitemap
NEXT_PUBLIC_SITE_URL=https://issa-capital.com

# Rate limiting (optionnel — defaults : 5 requêtes / 10 min)
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=600000

# Drive Inbox — sous-dossiers pré-configurés (optionnel)
# Si définis, le bot utilise ces IDs directement au lieu de chercher/créer les sous-dossiers.
# Résout le problème de doublons sur cold start serverless (scope drive.file + cache perdu).
# Pour obtenir l'ID : ouvrir le dossier dans Google Drive → copier l'ID depuis l'URL.
DRIVE_INBOX_PHOTOS_FOLDER_ID=
DRIVE_INBOX_NOTES_FOLDER_ID=
DRIVE_INBOX_VOICE_FOLDER_ID=
DRIVE_INBOX_DOCUMENTS_FOLDER_ID=

# Drive Quittances — dossier parent pour les quittances de loyer (optionnel)
# Si défini, les quittances sont uploadées dans DRIVE_QUITTANCES_FOLDER_ID/{Locataire}/
# Si absent, le bot crée un sous-dossier "Quittances" dans le dossier Inbox.
DRIVE_QUITTANCES_FOLDER_ID=

# Drive Vault Root — ID du dossier racine Obsidian sur Drive (optionnel)
# Utilisé pour naviguer vers 07. Contacts/05. Locataires/01. Actuels/
# Si absent, utilise DRIVE_INBOX_FOLDER_ID comme point de départ.
DRIVE_VAULT_ROOT_ID=

# Drive Todo.md — ID du fichier Todo.md dans le vault (optionnel)
# Si défini, skip la recherche et accède directement au fichier.
# Pour obtenir l'ID : ouvrir Todo.md dans Google Drive → copier l'ID depuis l'URL.
DRIVE_TODO_FILE_ID=

# Token admin pour /api/telegram/setup (menu commandes Telegram)
# Générer avec : openssl rand -hex 32
ADMIN_SETUP_TOKEN=

# Gmail — email-ingest Anya (Phase 1A, Jalon 2+)
# Email du compte Gmail à surveiller
GMAIL_USER_EMAIL=thomas.issa@gmail.com
# Nom du label Gmail pour marquer les emails traités (créer manuellement dans Gmail)
GMAIL_LABEL_TRAITE=Anya/traité
# Nom du label Gmail pour marquer les emails en erreur (créer manuellement dans Gmail)
GMAIL_LABEL_A_REVOIR=Anya/à-revoir

# Email-ingest — configuration polling (Phase 1A, Jalon 4+)
# Activer/désactiver le polling email
EMAIL_INGEST_ENABLED=true
# Intervalle de polling en minutes
EMAIL_INGEST_INTERVAL_MIN=5
# Nombre de jours de lookback pour les emails
EMAIL_INGEST_LOOKBACK_DAYS=7
# Mode dry-run (lecture seule, pas de modification)
EMAIL_INGEST_DRY_RUN=false

# Telegram (déjà utilisé S13 — réutilise les mêmes secrets)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_THOMAS=

# Email-ingest endpoint trigger (Jalon 4C)
# Secret pour POST /api/secretariat/email-ingest?secret=<token>
# Générer avec : openssl rand -hex 32
EMAIL_INGEST_TRIGGER_SECRET=

# Cron email-ingest (Jalon 5A — S15)
# Secret pour GET /api/secretariat/cron-email-ingest (Authorization: Bearer <token>)
# Utilisé par le scheduled task Replit (toutes les 1h).
# Générer avec : openssl rand -hex 32
CRON_SECRET=

# TickTick — intégration bidirectionnelle (Jalon 5C — S15)
# OAuth app TickTick (créer sur https://developer.ticktick.com)
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=
# Access token TickTick (obtenu via GET /api/secretariat/ticktick/oauth/init → callback).
# TickTick n'émet PAS de refresh_token (stratégie 180j sur access_token).
# À ré-autoriser tous les ~5 mois via /api/secretariat/ticktick/oauth/init.
TICKTICK_ACCESS_TOKEN=
# (legacy, rarement renseigné car TickTick n'émet pas de refresh_token)
TICKTICK_REFRESH_TOKEN=
# (TICKTICK_WEBHOOK_SECRET retiré S15.2.1 — TickTick API ne supporte pas les webhooks,
#  bascule sur polling 15 min via GitHub Actions, voir cron-ticktick-poll.yml)
# Secret query param pour l'endpoint iCal public (lecture seule)
# Générer avec : openssl rand -hex 16
TICKTICK_ICAL_SECRET=
