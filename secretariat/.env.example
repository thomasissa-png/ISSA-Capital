# ISSA Capital — Agent Secrétariat
# .env.example — TEMPLATE (versionné, pas de secrets)
# Copier en .env.local et remplir les valeurs réelles.

# --- Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=2000

# --- Craft API ---
CRAFT_IC_BASE_URL=https://connect.craft.do/links/.../api/v1
CRAFT_IC_KEY=pdk_...

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_CLOUD_API_TOKEN=EAAG...
WHATSAPP_PHONE_ID=123...
WHATSAPP_VERIFY_TOKEN=randomtoken123
WHATSAPP_WEBHOOK_SECRET=meta_webhook_secret
WHATSAPP_WHITELIST_E164=+33600000000

# --- Telegram Bot API (connecteur alternatif a WhatsApp) ---
# Token obtenu via @BotFather sur Telegram.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Secret token configure via setWebhook (1-256 chars alphanum + underscore/dash).
# Telegram l'envoie dans le header X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=random_secret_for_telegram_webhook

# --- Serveur ---
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# --- DB ---
DB_PATH=./data/secretariat.db
DB_ENCRYPTION_KEY=32_bytes_hex_random_key

# --- Session ---
SESSION_TTL_HOURS=24

# --- Admin web (Phase 5) ---
# Genere avec : openssl rand -hex 32
# Doit faire >= 32 caracteres. Obligatoire en production.
JWT_SECRET=replace-with-openssl-rand-hex-32-minimum-32-chars

# Hash bcrypt du mot de passe admin (ne JAMAIS committer le mot de passe clair).
# Generer via : npx tsx scripts/generate-admin-hash.ts <motdepasse>
# V1 : mot de passe "allezpsg" (a CHANGER en production).
ADMIN_PASSWORD_HASH=$2a$10$changemeplaceholderhashbcryptgeneratemewithscript

# Duree de vie de la session admin en heures (cookie + JWT exp)
ADMIN_SESSION_TTL_HOURS=24

# --- Phase 6 — Universign RFC 3161 (horodatage qualifie) ---
# Cle API Universign (compte Thomas). Si absent ou egal a __TO_FILL__, le
# publisher continue sans token (log warn). En production, remplir dans les
# Replit Secrets pour conformite DGFiP.
UNIVERSIGN_API_KEY=__TO_FILL__
# URL de l'endpoint TSA Universign (ne pas changer sauf sandbox).
UNIVERSIGN_API_URL=https://ws.universign.eu/tsa/post/

# --- Phase 6 — Backups SQLite ---
# Retention locale (nombre de fichiers dans data/backups/ conserves).
BACKUP_LOCAL_RETENTION=30
# Upload cloud optionnel (aws-sdk / b2-node-js non installes en Phase 6).
BACKUP_S3_ENABLED=false
BACKUP_B2_ENABLED=false
